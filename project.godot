; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Gay Game"
run/main_scene="uid://b76vij71sl6tt"
config/use_custom_user_dir=true
config/custom_user_dir_name="GameDirectory"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Prototyping/OLD/Sprites/icon.svg"

[autoload]

Shaker="*uid://dpk87m0wcxk1p"
PhantomCameraManager="*uid://duq6jhf6unyis"
Database="*uid://btp0kaa5kbu0b"

[dialogue_manager]

runtime/balloon_path="res://Prototyping/CHASE/Movement Test/Dialogue/balloon.tscn"

[display]

window/size/mode=3
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"

[editor_plugins]

enabled=PackedStringArray("res://addons/phantom_camera/plugin.cfg", "res://addons/shaker/plugin.cfg")

[file_customization]

folder_colors={
"res://MAIN/": "green",
"res://MAIN/Scenes/": "teal",
"res://MAIN/Scripts/": "pink",
"res://Prototyping/CHASE/": "purple",
"res://Prototyping/Imported Mesh/": "gray",
"res://Prototyping/Imported Textures/": "gray",
"res://Prototyping/OLD/": "red",
"res://Prototyping/VICTOR/": "purple",
"res://Scenes/Entities/": "green"
}

[global_group]

Camera=""
Interaction=""
Player=""
Database=""
UI=""

